# Copie este arquivo para .env e ajuste os valores conforme seu ambiente local.
# O .env e carregado pelo Spring Boot via spring.config.import no application.properties.
# Cada variavel tem um valor padrao no application.properties, entao defina apenas o que precisar sobrescrever.

# --- Banco de dados (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=haras_db
DB_USERNAME=root
DB_PASSWORD=admin123

# --- Servidor ---
SERVER_PORT=8080
